{
  "name": "mapcode-rest-service-ts",
  "version": "2.4.19.3",
  "description": "TypeScript port of the Mapcode REST API service.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --experimental-strip-types src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "fastify": "^5.2.0",
    "flatbush": "^4.4.0",
    "flatgeobuf": "^3.36.0",
    "mapcode-ts": "1.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
